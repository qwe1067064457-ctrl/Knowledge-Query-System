{
  "memory_policy": {
    "enabled_memory_types": [
      "core",
      "daily_log",
      "domain_case"
    ],
    "core": {
      "explicit_markers": [
        "以后",
        "默认",
        "始终",
        "总是",
        "统一",
        "偏好",
        "习惯",
        "请一直",
        "后续都"
      ],
      "group_scope_keywords": [
        "法律",
        "法条",
        "判例",
        "违约",
        "合同",
        "证据",
        "诉讼",
        "医学",
        "病例",
        "诊断",
        "风险",
        "分诊",
        "禁忌",
        "病人"
      ],
      "min_candidate_length": 6,
      "max_candidate_length": 120
    },
    "daily_log": {
      "checkpoint_enabled": true
    },
    "domain_case": {
      "completion_markers": [
        "已完成",
        "完成",
        "结论",
        "建议",
        "总结",
        "最终",
        "方案"
      ],
      "structural_markers": [
        "问题",
        "分析",
        "结论",
        "建议",
        "适用"
      ],
      "case_markers": [
        "案例",
        "判例",
        "病例"
      ]
    }
  }
}
